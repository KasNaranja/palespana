# ─────────────────────────────────────────────────────────────
# CazaPAL — configuración
# Copia este archivo a `.env.local` y rellena lo que necesites.
# Sin claves, la app arranca en MODO DEMO con datos de ejemplo.
#
# En la app de escritorio (.exe) no necesitas tocar esto: la clave se pega
# en la pantalla de ajustes la primera vez que abres el programa.
# ─────────────────────────────────────────────────────────────

# Clave GRATUITA de Google Gemini para el análisis de idioma por visión.
# Consíguela en https://aistudio.google.com  →  "Get API key".
# Sin ella, los veredictos vienen precargados del ejemplo (modo demo).
GEMINI_API_KEY=

# Modelo multimodal de Gemini (nivel gratuito) a usar para analizar las fotos.
GEMINI_VISION_MODEL=gemini-2.5-flash

# Milisegundos mínimos entre llamadas a Gemini (el nivel gratuito limita las
# peticiones por minuto). 4500 ms ≈ 13/min, seguro para el plan gratis.
GEMINI_MIN_INTERVAL_MS=4500

# Habilitar la consulta real a Vinted (por defecto desactivado -> modo demo).
ENABLE_VINTED=false

# Dominio de Vinted a consultar.
VINTED_HOST=www.vinted.es

# Forzar modo demo aunque haya claves (útil para enseñar la app).
# DEMO_MODE=true

# Ruta del fichero de caché (por defecto ./data/cache.json).
# CAZAPAL_DB_PATH=./data/cache.json

# ── Caché persistente (opcional, recomendado en la nube) ──────────────
# Upstash Redis (plan gratis). Sin estas dos, la caché es en memoria/fichero y
# se pierde en cada despliegue (re-analiza y gasta cuota de Gemini). Con ellas,
# cada anuncio se analiza una vez y se reutiliza para siempre.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
